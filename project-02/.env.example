# Projekat 2 — konfiguracija (kopirati u .env i menjati po potrebi)
# Brokera biramo profilom docker compose-a (--profile mqtt | --profile kafka).
# Promenljive ispod kontrolišu ponašanje servisa pri svakom eksperimentu.

# ── MQTT garancije isporuke ───────────────────────────────────────────────
# 0 = at most once, 1 = at least once, 2 = exactly once
MQTT_QOS=1

# ── Kafka potvrda prijema ─────────────────────────────────────────────────
# 0 = bez potvrde, 1 = lider potvrđuje, all = svi in-sync replikatori
KAFKA_ACKS=1

# ── Analytics (tumbling window) ───────────────────────────────────────────
ALERT_THRESHOLD=50          # °C — prosek prozora iznad ovoga -> KRITIČAN ALARM
WINDOW_SECONDS=10           # dužina fiksnog (tumbling) prozora

# ── Storage (batching / I/O optimizacija) ─────────────────────────────────
STORAGE_WRITE_ENABLED=true  # false = bez upisa u bazu (Scenariji A i C, da broker bude usko grlo)
STORAGE_BATCH_SIZE=500      # grupni upis na svakih N poruka
STORAGE_FLUSH_MS=2000       # ili flush na svakih N ms (da poslednje poruke ne čekaju)

# ── Ingestion (simulacija uređaja) ────────────────────────────────────────
DEVICE_COUNT=100            # broj simuliranih uređaja
MSG_RATE=10                 # poruka po sekundi po uređaju
CRITICAL_MODE=false         # true = ubacuje >50°C očitavanja (Scenario D — alerting)
